# =============================================================================
# operator-common-iterator 环境配置
# 复制本文件为 .env 后填入真实密钥；.env 已被 .gitignore 忽略，不会入库
# 字段定义见 config.py 中的 Settings
# =============================================================================

# ---- LLM 厂商选择 ----
# 可选值：zai | deepseek
LLM_PROVIDER=deepseek

# ---- DeepSeek ----
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# ---- Z.AI ----
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/
ZAI_MODEL=glm-5.1

# ---- CLI Agent (agent backend) ----
CLI_AGENT_BIN=claude
CLI_AGENT_ARGS=-p {prompt} --print --output-format text

# ---- 共用参数 ----
# 取值范围 [0.0, 2.0]
LLM_TEMPERATURE=0.1

# ---- LLM 调用超时（流式调用）----
# 单个 SSE chunk 之间的最大空闲间隔（秒），超出视为服务端卡死并主动 abort
# 取值范围 [1.0, 600.0]
LLM_CHUNK_IDLE_TIMEOUT=60.0
# 单次 LLM 调用的总超时（秒，httpx read timeout 兜底）
# 取值范围 [10.0, 3600.0]
LLM_TOTAL_TIMEOUT=600.0

# 调试开关：把 LLM 流式响应实时打印到 stderr
# 适用所有 backend：APIBackend（DeepSeek/Z.AI/OpenAI 兼容）+ CliAgentBackend
# - APIBackend：按 [think ↓] / [answer ↓] 分两段打印，支持 reasoning_content
# - CliAgentBackend：原样转子进程 stdout，标 [cli-stream ↓]
# 取值 true | false（默认 false）
# 注意：长响应会刷屏，正式跑批时务必关掉
LLM_STREAM_CONSOLE_OUTPUT=false
# 进度日志间隔（秒）：每隔 N 秒打一次 throughput（chunks/字节/速度）
# 仅对 APIBackend 生效。CliAgentBackend 走 heartbeat 机制（5s 一次）
# 取值范围 [0.5, 60.0]，默认 3.0。值越小日志越频繁但能更及时看到 LLM 是否活跃
LLM_PROGRESS_LOG_INTERVAL=3.0

# ---- 调试（可选）----
# 打开 langchain/httpx 的 DEBUG 日志：diag_langchain.py 使用
# HTTPX_LOG_LEVEL=DEBUG